---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Stránka nenalezena — Salon SiLi" noindex>
  <Header />
  <main id="main-content" class="mx-auto max-w-2xl px-gutter py-section text-center">
    <h1 class="font-display text-display">404</h1>
    <p class="mt-4 text-muted">Tato stránka neexistuje.</p>
    <a href="/" class="label-mono mt-8 inline-block text-accent hover:underline">Zpět na hlavní stránku →</a>
  </main>
  <Footer />
</Base>
