---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PriceTable from '../components/PriceTable.astro';
import Faq from '../components/Faq.astro';
import ContactSection from '../components/ContactSection.astro';
import { services } from '../data/services';
import { pricesByIds } from '../data/pricing';
import { useTranslations } from '../i18n/ui';
import handsNails from '../assets/stock/hands-nails.jpg';
import eucalyptus from '../assets/stock/eucalyptus.jpg';

const t = useTranslations('cs');

const serviceImages: Record<string, { src: ImageMetadata; alt: string }> = {
  manikura: { src: handsNails, alt: 'Detail gelové manikúry na rukou klientky' },
};

export function getStaticPaths() {
  return services.map((service) => ({ params: { slug: service.slug }, props: { service } }));
}

const { service } = Astro.props;
const priceItems = pricesByIds(service.priceIds);
const title = `${service.title} — Salon SiLi Liberec`;
const heroImage = serviceImages[service.slug] ?? {
  src: eucalyptus,
  alt: `Detail ošetření — ${service.title}`,
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: service.faq.map((item: { q: string; a: string }) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: service.title,
  provider: { '@type': 'BeautySalon', name: 'Salon SiLi' },
  areaServed: 'Liberec',
};
---

<Base title={title} description={service.short}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <Header />
  <main id="main-content">
    <section class="mx-auto max-w-4xl px-gutter py-section">
      <p class="label-mono text-accent-strong">Služba — Liberec</p>
      <h1 class="font-display text-display mt-2">{service.title}</h1>
      <div class="rule-gold mt-4 w-24"></div>
      <p class="mt-6 max-w-2xl text-lg text-muted">{service.short}</p>

      <div class="mt-10 aspect-[16/9] max-w-2xl overflow-hidden rounded-[1.5rem]">
        <Image
          src={heroImage.src}
          alt={heroImage.alt}
          widths={[500, 900]}
          sizes="(min-width: 768px) 42rem, 90vw"
          quality={45}
          loading="lazy"
          class="img-warm h-full w-full object-cover"
        />
      </div>

      <ul class="mt-10 space-y-3">
        {
          service.benefits.map((benefit: string) => (
            <li class="flex gap-3 text-ink">
              <span class="text-accent">—</span>
              {benefit}
            </li>
          ))
        }
      </ul>

      <h2 class="font-display text-title mt-16">Jak ošetření probíhá</h2>
      <ol class="mt-6 space-y-4">
        {
          service.process.map((step: string, i: number) => (
            <li class="flex gap-4">
              <span class="label-mono text-accent-strong">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-ink">{step}</span>
            </li>
          ))
        }
      </ol>

      {
        priceItems.length > 0 && (
          <>
            <h2 class="font-display text-title mt-16">Ceny</h2>
            <div class="mt-6 max-w-lg">
              <PriceTable items={priceItems} />
            </div>
          </>
        )
      }

      <div class="mt-16">
        <Faq items={service.faq} />
      </div>

      <div class="mt-16">
        <a
          href="/#kontakt"
          class="label-mono inline-block border border-ink px-6 py-3 text-ink transition-colors hover:border-accent hover:text-accent"
        >
          {t('nav.callCta')}
        </a>
      </div>

      <p class="mt-16 max-w-xl border-t border-hairline pt-6 text-xs text-muted">
        {t('hygiene.note')} {t('medical.disclaimer')}
      </p>
    </section>

    <ContactSection />
  </main>
  <Footer />
</Base>
