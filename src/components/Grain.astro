---
// Fixed film-grain texture — masks stock-photo slickness, kept faint (see .grain-overlay).
// prefers-reduced-motion is irrelevant here (it's static), but respecting print/high-contrast
// modes is handled by keeping opacity low enough to never affect legibility.
---

<svg class="grain-overlay" aria-hidden="true" focusable="false">
  <filter id="grain">
    <feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="2" stitchTiles="stitch" />
  </filter>
  <rect width="100%" height="100%" filter="url(#grain)" />
</svg>
