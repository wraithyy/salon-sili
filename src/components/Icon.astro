---
// Minimal thin-stroke icon set, inline — no icon-font dependency.
// Used sparingly: contact utility icons only, never as decorative grids.
const paths: Record<string, string> = {
  phone: 'M6.5 3.5h3l1.5 4-2 1.5a11 11 0 0 0 5 5l1.5-2 4 1.5v3a1.5 1.5 0 0 1-1.5 1.5C10 18 6 14 6 6.5A1.5 1.5 0 0 1 6.5 3.5Z',
  pin: 'M12 21s7-6.4 7-11.5A7 7 0 0 0 5 9.5C5 14.6 12 21 12 21Z M12 11.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z',
  mail: 'M4 6h16v12H4V6Z M4 6l8 7 8-7',
};

interface Props {
  name: keyof typeof paths;
  class?: string;
}
const { name, class: className = 'h-5 w-5' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.25"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d={paths[name]} />
</svg>
