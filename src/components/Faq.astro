---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  items: { q: string; a: string }[];
  lang?: Lang;
}
const { items, lang = 'cs' } = Astro.props;
const t = useTranslations(lang);
---

<div>
  <p class="label-mono text-accent-strong">{t('faq.label')}</p>
  <div class="mt-6 divide-y divide-hairline border-y border-hairline">
    {
      items.map((item) => (
        <details class="group py-4">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-lg text-ink">
            {item.q}
            <span class="shrink-0 text-accent transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="mt-3 text-muted">{item.a}</p>
        </details>
      ))
    }
  </div>
</div>
