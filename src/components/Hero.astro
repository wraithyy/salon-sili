---
import { Image } from 'astro:assets';
import brush from '../assets/brush.jpeg';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'cs' } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="hero"
  class="relative overflow-hidden bg-hero-bg text-hero-ink"
  data-surface="dark"
  data-cursor-glow
>
  <Image
    src={brush}
    alt=""
    widths={[640, 1024, 1600, 1920]}
    sizes="100vw"
    quality={55}
    loading="eager"
    fetchpriority="high"
    id="hero-image"
    style="object-position: 20% 30%;"
    class="absolute inset-0 h-full w-full object-cover opacity-70 will-change-transform"
  />
  <div class="absolute inset-0 bg-hero-bg/40"></div>
  <div
    id="hero-glow"
    class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500"
    style="background: radial-gradient(420px circle at var(--mx, 50%) var(--my, 50%), color-mix(in srgb, var(--hero-gold) 18%, transparent), transparent 70%);"
  >
  </div>
  <div class="pointer-events-none absolute inset-3 border border-hero-gold/25 sm:inset-6"></div>
  <div class="relative mx-auto flex min-h-[80vh] max-w-6xl flex-col justify-center gap-6 px-gutter py-24">
    <p class="label-mono text-hero-gold" data-hero-in style="--d: 0ms">{t('hero.kicker')}</p>
    <h1 class="font-display text-display max-w-3xl text-hero-ink" data-hero-in style="--d: 90ms">
      {t('hero.headline')}
    </h1>
    <p class="max-w-xl text-lg text-hero-ink/85" data-hero-in style="--d: 200ms">{t('hero.subhead')}</p>
    <div class="mt-4" data-hero-in style="--d: 300ms">
      <a
        href="#kontakt"
        class="label-mono inline-block border border-hero-gold px-6 py-3 text-hero-gold transition-colors hover:bg-hero-gold hover:text-hero-bg"
      >
        {t('hero.cta')}
      </a>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: no-preference) {
    [data-hero-in] {
      opacity: 0;
      transform: translateY(0.9rem);
      letter-spacing: 0.02em;
      animation: hero-in 800ms cubic-bezier(0.22, 1, 0.36, 1) var(--d, 0ms) both;
    }
    @keyframes hero-in {
      to {
        opacity: 1;
        transform: translateY(0);
        letter-spacing: normal;
      }
    }
  }
</style>

<script>
  // Slow parallax on the hero image — inert under prefers-reduced-motion.
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const img = document.getElementById('hero-image');
  if (img && !reduceMotion) {
    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        img.style.transform = `translateY(${window.scrollY * 0.15}px)`;
        ticking = false;
      });
    };
    document.addEventListener('scroll', onScroll, { passive: true });
  }

  // Wow-touch, kept cheap: a soft gold glow that follows the pointer over the
  // hero — pure CSS custom-property update, no canvas/WebGL. Pointer-only
  // (touch devices have no hover) and off under prefers-reduced-motion.
  const hero = document.getElementById('hero');
  const glow = document.getElementById('hero-glow');
  if (hero && glow && !reduceMotion && matchMedia('(hover: hover)').matches) {
    hero.addEventListener('pointermove', (e) => {
      const rect = hero.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      glow.style.setProperty('--mx', `${x}%`);
      glow.style.setProperty('--my', `${y}%`);
      glow.style.opacity = '1';
    });
    hero.addEventListener('pointerleave', () => {
      glow.style.opacity = '0';
    });
  }
</script>
