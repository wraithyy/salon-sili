---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'cs' } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { href: '/#sluzby', label: t('nav.services') },
  { href: '/cenik/', label: t('nav.pricing') },
  { href: '/#kontakt', label: t('nav.contact') },
];
---

<header class="relative border-b border-hairline">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-gutter py-5">
    <a href="/" class="font-script text-4xl leading-none text-ink" aria-label="Salon SiLi — domů">SiLi</a>
    <nav class="hidden items-center gap-8 sm:flex" aria-label="Hlavní navigace">
      {navLinks.map((link) => (
        <a href={link.href} class="text-sm font-semibold tracking-wide text-ink transition-colors hover:text-accent">
          {link.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a
        href="/#kontakt"
        class="label-mono hidden shrink-0 border border-ink px-4 py-2 text-ink transition-colors hover:border-accent hover:text-accent sm:inline-block"
      >
        {t('nav.callCta')}
      </a>
      <details class="group sm:hidden">
        <summary
          class="flex h-10 w-10 cursor-pointer list-none items-center justify-center [&::-webkit-details-marker]:hidden"
          aria-label={t('nav.menu')}
        >
          <span class="relative block h-3.5 w-5">
            <span class="absolute inset-x-0 top-0 h-px bg-ink" />
            <span class="absolute inset-x-0 top-1/2 h-px -translate-y-1/2 bg-ink" />
            <span class="absolute inset-x-0 bottom-0 h-px bg-ink" />
          </span>
        </summary>
        <nav
          class="absolute inset-x-0 top-full z-50 flex flex-col gap-1 border-b border-hairline bg-paper px-gutter py-4"
          aria-label="Hlavní navigace"
        >
          {navLinks.map((link) => (
            <a href={link.href} class="py-2 text-sm font-semibold text-ink">
              {link.label}
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>
